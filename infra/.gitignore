# Local .terraform directory (cached providers and modules)
.terraform/

# .tfstate files (Contains secrets and local state; use remote backends instead)
*.tfstate
*.tfstate.*

# Crash logs
crash.log
crash.*.log

# Sensitive variable files (Keep secrets out of version control)
*.tfvars
*.tfvars.json

# Local override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# .terraformrc or terraform.rc (CLI configuration files)
.terraformrc
terraform.rc

# Terraform lock file (optional - some teams commit this)
.terraform.lock.hcl

# Terraform plan files (optional - some teams commit these)
*.tfplan

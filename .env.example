# GCP Settings
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=US
GOOGLE_APPLICATION_CREDENTIALS=/app/secrets/sa-key.json

# Lakehouse Settings
LAKEHOUSE_BUCKET=gs://chicago-311-lakehouse-bucket

# Nessie Catalog Settings
NESSIE_URI=http://localhost:19120/api/v1

# Supabase Database Credentials for Nessie Catalog
# Get the JDBC connection string from Supabase Dashboard > Settings > Database
# Replace [YOUR-PASSWORD] with your actual password
POSTGRES_JDBC=jdbc:postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-ID].supabase.co:5432/postgres

# Individual components (for reference, not used by docker-compose)
POSTGRES_PASSWORD=[YOUR-PASSWORD]
POSTGRES_HOST=db.[YOUR-PROJECT-ID].supabase.co
POSTGRES_PORT=5432

# Socrata API
SOCRATA_APP_TOKEN=your_token_here
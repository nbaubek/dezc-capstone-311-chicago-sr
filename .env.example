# GCP Settings
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=US
GOOGLE_APPLICATION_CREDENTIALS=/app/secrets/sa-key.json

# Lakehouse Settings
LAKEHOUSE_BUCKET=gs://chicago-311-lakehouse-bucket

# Iceberg Catalog Settings (Neon PostgreSQL)
# Get the connection string from Neon Dashboard > Connection Details
ICEBERG_CATALOG_URI=postgresql://user:password@host:port/database?sslmode=require

# Socrata API
SOCRATA_APP_TOKEN=your_token_here